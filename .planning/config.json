{
  "mode": "yolo",
  "granularity": "coarse",
  "parallelization": true,
  "commit_docs": true,
  "model_profile": "quality",
  "workflow": {
    "research": true,
    "plan_check": false,
    "verifier": false,
    "nyquist_validation": false,
    "auto_advance": true,
    "ui_phase": true,
    "ui_safety_gate": true,
    "skip_discuss": true,
    "use_worktrees": true,
    "_auto_chain_active": true
  },
  "git": {
    "branching_strategy": "milestone",
    "milestone_branch_template": "gsd/{milestone}-{slug}"
  },
  "hooks": {
    "context_warnings": false
  }
}